# AI Visibility Tracker — environment variables
# Copy to .env.local for local dev. Set the same on Vercel (except the AI keys).

# Database: when both are set, the app reads/writes Supabase instead of data/db.json.
# Vercel needs these two so the dashboard can read audit data.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Provider mode: false = live Gemini/OpenAI calls, true = mock data.
DEMO_MODE=false

# AI provider keys — LOCAL ONLY (audits run on Shan's machine). Do NOT set on Vercel.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: parallel audit workers (default 6).
AUDIT_CONCURRENCY=10
